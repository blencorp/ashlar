{
  "schemaVersion": "2.1.0",
  "modules": [
    {
      "kind": "javascript-module",
      "path": "date-input.html",
      "declarations": [
        {
          "kind": "class",
          "name": "AshlarDateInput",
          "tagName": "input",
          "description": "Native single-date input for simple public-service date questions.",
          "_ashlar": {
            "version": "0.0.1",
            "tier": "primitive",
            "layer": "L0",
            "stability": "experimental",
            "selector": ".ashlar-date-input",
            "a11yRequirements": [
              {
                "id": "native-date-input-required",
                "wcag": "4.1.2",
                "severity": "error",
                "description": "Simple date fields should use native input semantics for keyboard, name, role, and value."
              },
              {
                "id": "accessible-name-required",
                "wcag": "3.3.2",
                "severity": "error",
                "description": "Date inputs must have a visible label or equivalent accessible name."
              },
              {
                "id": "invalid-date-input-describedby",
                "wcag": "3.3.1",
                "severity": "error",
                "description": "Invalid date inputs must connect their error text with aria-describedby."
              },
              {
                "id": "focus-visible-required",
                "wcag": "2.4.7",
                "severity": "error",
                "description": "Keyboard focus must be visually distinct."
              }
            ],
            "antiPatterns": [
              {
                "id": "date-input-needs-associated-label",
                "pattern": "<input $$$ATTRS>",
                "regex": "class=\"[^\"]*\\bashlar-date-input\\b",
                "not": {
                  "regex": "\\b(id|aria-label|aria-labelledby)\\s*="
                },
                "message": "Ashlar Date Input requires an id plus associated label, aria-label, or aria-labelledby.",
                "fix": "Add an id and a visible label with matching for, or provide aria-labelledby.",
                "wcag": "3.3.2",
                "severity": "error",
                "languages": ["html"]
              },
              {
                "id": "invalid-date-input-needs-describedby",
                "pattern": "<input $$$ATTRS>",
                "regex": "class=\"[^\"]*\\bashlar-date-input\\b[\\s\\S]*aria-invalid=\"true\"",
                "not": {
                  "regex": "aria-describedby\\s*="
                },
                "message": "Invalid Ashlar Date Input requires aria-describedby pointing to error text.",
                "fix": "Add aria-describedby with the error message id.",
                "wcag": "3.3.1",
                "severity": "error",
                "languages": ["html"]
              }
            ],
            "tokensConsumed": [
              "color.surface",
              "color.input.border",
              "color.text",
              "color.status.error.border",
              "focus.ring.color",
              "radius.control"
            ],
            "platformFeatures": [
              {
                "feature": "native-date-input",
                "status": "required",
                "fallback": "Uses input type=date for platform date entry; browsers without native support fall back to text entry, so pair with visible format guidance when needed."
              },
              {
                "feature": "forced-colors",
                "status": "progressive",
                "fallback": "Uses system field, text, border, and focus colors."
              }
            ],
            "policyMappings": [
              {
                "source": "Section 508",
                "requirement": "Supports form control name, role, value, labels, keyboard operation, and error relationships for simple date fields when used correctly.",
                "url": "https://www.section508.gov/"
              }
            ],
            "rendering": "server-safe",
            "hydrationCost": "none",
            "criticalForA11y": true
          }
        }
      ]
    }
  ]
}
