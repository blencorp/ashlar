{
  "name": "@ashlar/example-vite",
  "version": "0.0.3",
  "private": true,
  "description": "Public-service page-shell Vite reference app for Ashlar. Demonstrates live agency theme switching driven by DTCG tokens.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src"
  },
  "devDependencies": {
    "@ashlar/cli": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
