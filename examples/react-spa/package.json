{
  "name": "@ashlar/example-react-spa",
  "version": "0.0.2",
  "private": true,
  "description": "React SPA Ashlar reference app.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4181 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4181 --strictPort",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run audit",
    "lint": "biome lint src vite.config.ts",
    "audit": "node ../../packages/cli/dist/index.js audit --policy federal --registry ../../registry public/audit.html && node ../../packages/cli/dist/index.js audit --policy components --registry ../../registry public/audit.html src/App.tsx src/styles.css"
  },
  "devDependencies": {
    "@ashlar/cli": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
