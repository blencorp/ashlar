{
  "$schema": "https://ashlar.dev/schemas/agency-theme.schema.json",
  "name": "va",
  "title": "VA",
  "description": "VA.gov source-derived service theme grounded in VA semantic color and typography guidance. Not an official VA brand specification or endorsement.",
  "provenance": {
    "status": "source-derived",
    "reviewedAt": "2026-05-07",
    "reviewedBy": "BLEN",
    "summary": "Derived from public VA.gov Design System color and typography sources; not published or endorsed by the Department of Veterans Affairs."
  },
  "sources": [
    {
      "label": "VA.gov color palette",
      "url": "https://design.va.gov/foundation/color-palette",
      "note": "Uses VA semantic colors, including vads-color-primary and base text values.",
      "retrievedAt": "2026-05-07",
      "tokenPaths": ["color.action.primary.*", "color.text.*", "color.focus", "color.status.*"]
    },
    {
      "label": "VA.gov typography",
      "url": "https://design.va.gov/foundation/typography",
      "note": "Uses VA's Source Sans Pro sans-serif stack and VA typography scale references.",
      "retrievedAt": "2026-05-07",
      "tokenPaths": ["font.sans"]
    }
  ],
  "order": 10,
  "tokens": {
    "color": {
      "page": {
        "$type": "color",
        "$value": "#f5f7fa"
      },
      "surface": {
        "$type": "color",
        "$value": "#ffffff"
      },
      "surfaceRaised": {
        "$type": "color",
        "$value": "#ffffff"
      },
      "surfaceSubtle": {
        "$type": "color",
        "$value": "#e6eef7"
      },
      "surfaceMuted": {
        "$type": "color",
        "$value": "{color.surfaceSubtle}"
      },
      "border": {
        "$type": "color",
        "$value": "#a9aeb1"
      },
      "borderSubtle": {
        "$type": "color",
        "$value": "{color.border}"
      },
      "inputBorder": {
        "$type": "color",
        "$value": "{color.border}"
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "#1b1b1b"
        },
        "muted": {
          "$type": "color",
          "$value": "#565c65"
        },
        "inverse": {
          "$type": "color",
          "$value": "#ffffff"
        },
        "inverseMuted": {
          "$type": "color",
          "$value": "color-mix(in srgb, var(--ashlar-color-text-inverse), transparent 24%)"
        }
      },
      "action": {
        "primary": {
          "bg": {
            "$type": "color",
            "$value": "#005ea2"
          },
          "fg": {
            "$type": "color",
            "$value": "#ffffff"
          },
          "hover": {
            "$type": "color",
            "$value": "#1a4480"
          }
        },
        "secondary": {
          "bg": {
            "$type": "color",
            "$value": "#ffffff"
          },
          "fg": {
            "$type": "color",
            "$value": "#005ea2"
          },
          "border": {
            "$type": "color",
            "$value": "#005ea2"
          }
        }
      },
      "link": {
        "$type": "color",
        "$value": "{color.action.secondary.fg}"
      },
      "linkInverse": {
        "$type": "color",
        "$value": "{color.text.inverse}"
      },
      "focus": {
        "$type": "color",
        "$value": "#face00"
      },
      "status": {
        "infoBg": {
          "$type": "color",
          "$value": "#e7f6f8"
        },
        "infoFg": {
          "$type": "color",
          "$value": "#1b1b1b"
        },
        "infoBorder": {
          "$type": "color",
          "$value": "{color.action.primary.bg}"
        },
        "successBg": {
          "$type": "color",
          "$value": "#ecf3ec"
        },
        "warningBg": {
          "$type": "color",
          "$value": "#faf3d1"
        },
        "errorBg": {
          "$type": "color",
          "$value": "#f4e3db"
        },
        "errorBorder": {
          "$type": "color",
          "$value": "#d54309"
        },
        "errorFg": {
          "$type": "color",
          "$value": "#b50909"
        }
      }
    },
    "font": {
      "sans": {
        "$type": "fontFamily",
        "$value": "\"Source Sans Pro\", \"Source Sans 3\", \"Public Sans\", system-ui, sans-serif"
      }
    },
    "radius": {
      "control": {
        "$type": "dimension",
        "$value": "0.25rem"
      },
      "card": {
        "$type": "dimension",
        "$value": "0.125rem"
      },
      "panel": {
        "$type": "dimension",
        "$value": "0.25rem"
      }
    },
    "elevation": {
      "card": {
        "$type": "shadow",
        "$value": "none"
      },
      "panel": {
        "$type": "shadow",
        "$value": "0 2px 6px rgb(27 27 27 / 0.08)"
      }
    },
    "component": {
      "button": {
        "radius": {
          "$type": "dimension",
          "$value": "{radius.control}"
        },
        "minBlockSize": {
          "$type": "dimension",
          "$value": "2.875rem"
        }
      },
      "card": {
        "radius": {
          "$type": "dimension",
          "$value": "{radius.card}"
        },
        "shadow": {
          "$type": "shadow",
          "$value": "{elevation.card}"
        }
      }
    },
    "focus": {
      "ring": {
        "color": {
          "$type": "color",
          "$value": "{color.focus}"
        },
        "width": {
          "$type": "dimension",
          "$value": "0.25rem"
        },
        "offset": {
          "$type": "dimension",
          "$value": "0.18rem"
        }
      }
    }
  },
  "modes": {
