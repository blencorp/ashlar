{
  "name": "@ashlar/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Static first-run documentation site for Ashlar adoption.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4175 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4175 --strictPort",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
