{
  "$schema": "https://ashlar.dev/schemas/theme.schema.json",
  "name": "example-agency",
  "displayName": "Example Department of Civic Services",
  "version": "0.1.0",
  "extends": "ashlar/default",
  "tokens": {
    "color.brand.primary": {
      "$type": "color",
      "$value": "oklch(0.42 0.12 250)",
      "$description": "Primary brand color. Used for action.primary.bg by alias."
    },
    "color.brand.primary-emphasized": {
      "$type": "color",
      "$value": "oklch(0.32 0.14 250)"
    },
    "color.brand.secondary": {
      "$type": "color",
      "$value": "oklch(0.55 0.10 145)"
    },
    "color.action.primary.bg": {
      "$type": "color",
      "$value": "{color.brand.primary}"
    },
    "color.action.primary.fg": {
      "$type": "color",
      "$value": "white"
    },
    "color.action.primary.bg-hover": {
      "$type": "color",
      "$value": "{color.brand.primary-emphasized}"
    },
    "color.focus.ring": {
      "$type": "color",
      "$value": "{color.brand.primary}"
    },
    "font.sans": {
      "$type": "fontFamily",
      "$value": ["Public Sans", "system-ui", "sans-serif"]
    },
    "radius.md": {
      "$type": "dimension",
      "$value": "0.375rem"
    }
  },
  "modes": {
    "dark": {
      "color.brand.primary": {
        "$type": "color",
        "$value": "oklch(0.72 0.14 250)"
      },
      "color.action.primary.bg": {
        "$type": "color",
        "$value": "{color.brand.primary}"
      },
      "color.action.primary.bg-hover": {
        "$type": "color",
        "$value": "oklch(0.62 0.14 250)"
      }
    },
    "high-contrast": {
      "color.brand.primary": {
        "$type": "color",
        "$value": "ButtonText"
      },
      "color.action.primary.bg": {
        "$type": "color",
        "$value": "ButtonText"
      },
      "color.action.primary.fg": {
        "$type": "color",
        "$value": "ButtonFace"
      },
      "color.focus.ring": {
        "$type": "color",
        "$value": "Highlight"
      }
    }
  },
  "contrastPairs": [
    ["color.action.primary.fg", "color.action.primary.bg", "AA"],
    ["color.text.default", "color.surface.default", "AA"],
    ["color.text.muted", "color.surface.default", "AA"],
    ["color.error.fg", "color.error.bg", "AA"]
  ],
  "brandSource": {
    "agency": "Example Department of Civic Services",
    "guidelinesUrl": "https://example.gov/brand-guidelines",
    "guidelinesVersion": "2.4",
    "lastVerified": "2026-04-24"
  }
}
