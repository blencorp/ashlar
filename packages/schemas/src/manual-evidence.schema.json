{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ashlar.dev/schemas/manual-evidence.schema.json",
  "title": "Ashlar Manual Evidence Artifact",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "component",
    "version",
    "reviewedAt",
    "reviewer",
    "manualTests",
    "knownLimitations"
  ],
  "properties": {
    "$schema": {
      "const": "https://ashlar.dev/schemas/manual-evidence.schema.json"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "component": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string"
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "wcag": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "status", "evidence"],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "status": {
            "enum": ["pass", "fail", "not-applicable", "known-issue"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "baselineTests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "test", "status", "evidence"],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "test": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["pass", "fail", "not-applicable", "known-issue"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "manualTests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tech", "browser", "os", "date", "tester", "result"],
        "properties": {
          "tech": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string"
          },
          "browser": {
            "type": "string",
            "minLength": 1
          },
          "browserVersion": {
            "type": "string"
          },
          "os": {
            "type": "string",
            "minLength": 1
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "tester": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "enum": ["pass", "pass-with-note", "fail", "blocked"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "knownLimitations": {
      "type": "array",
      "items": {}
    }
  },
  "additionalProperties": false
}
