{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ashlar.dev/schemas/codemod.schema.json",
  "title": "Ashlar Capsule Codemod",
  "type": "object",
  "required": ["schemaVersion", "component", "from", "to", "rules"],
  "properties": {
    "$schema": {
      "const": "https://ashlar.dev/schemas/codemod.schema.json"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "component": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "target", "language", "pattern", "rewrite"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "target": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
          },
          "language": {
            "enum": ["html", "tsx", "jsx", "css", "typescript", "javascript"]
          },
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "rewrite": {
            "type": "string"
          },
          "confirm": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
