{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ashlar.dev/schemas/manual-transcript.schema.json",
  "title": "Ashlar Manual Transcript Artifact",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "component",
    "version",
    "transcriptType",
    "reviewedAt",
    "reviewer",
    "environment",
    "steps",
    "result",
    "summary"
  ],
  "properties": {
    "$schema": {
      "const": "https://ashlar.dev/schemas/manual-transcript.schema.json"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "component": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "transcriptType": {
      "enum": ["keyboard", "screen-reader"]
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "object",
      "required": ["browser", "os"],
      "properties": {
        "browser": {
          "type": "string",
          "minLength": 1
        },
        "browserVersion": {
          "type": "string"
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "assistiveTechnology": {
          "type": "string",
          "minLength": 1
        },
        "assistiveTechnologyVersion": {
          "type": "string"
        },
        "inputDevice": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "action", "expected", "observed", "result"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "expected": {
            "type": "string",
            "minLength": 1
          },
          "observed": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "enum": ["pass", "pass-with-note", "fail", "blocked"]
          }
        },
        "additionalProperties": false
      }
    },
    "result": {
      "enum": ["pass", "pass-with-note", "fail", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "knownLimitations": {
      "type": "array",
      "items": {}
    }
  },
  "if": {
    "properties": {
      "transcriptType": {
        "const": "screen-reader"
      }
    }
  },
  "then": {
    "properties": {
      "environment": {
        "required": ["browser", "os", "assistiveTechnology"]
      }
    }
  },
  "additionalProperties": false
}
