{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ashlar.dev/schemas/release-trust-bundle.schema.json",
  "title": "Ashlar Release Trust Bundle",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "tool",
    "generatedAt",
    "registry",
    "artifacts",
    "verification"
  ],
  "properties": {
    "$schema": {
      "const": "https://ashlar.dev/schemas/release-trust-bundle.schema.json"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "tool": {
      "const": "ashlar release trust-bundle"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "registry": {
      "type": "object",
      "required": [
        "path",
        "name",
        "version",
        "indexHash",
        "trustRootHash",
        "trustRoot",
        "capsuleCount",
        "capsules"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "indexHash": {
          "$ref": "#/$defs/sha256"
        },
        "trustRootHash": {
          "anyOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "trustRoot": {
          "anyOf": [
            {
              "$ref": "#/$defs/trustRoot"
            },
            {
              "type": "null"
            }
          ]
        },
        "capsuleCount": {
          "type": "integer",
          "minimum": 0
        },
        "capsules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capsuleSummary"
          }
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "verification": {
      "type": "object",
      "required": ["npmProvenance", "sigstore", "notes"],
      "properties": {
        "npmProvenance": {
          "const": "not-included"
        },
        "sigstore": {
          "const": "not-included"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact": {
      "type": "object",
      "required": ["type", "name", "sha256", "size"],
      "properties": {
        "type": {
          "enum": ["spdx-sbom", "release-artifact-attestation"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "capsuleSummary": {
      "type": "object",
      "required": ["name", "version", "layer", "stability", "capsuleHash", "signatureKeyId"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "enum": [
            "markup-primitives",
            "interactive-components",
            "framework-adapters",
            "service-patterns",
            "application-blocks"
          ]
        },
        "stability": {
          "enum": ["proposal", "experimental", "beta", "stable", "deprecated"]
        },
        "capsuleHash": {
          "$ref": "#/$defs/sha256"
        },
        "signatureKeyId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "trustRoot": {
      "type": "object",
      "required": ["schemaVersion", "keys"],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "schemaVersion": {
          "const": "1.0"
        },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["keyId", "algorithm", "publicKey"],
            "properties": {
              "keyId": {
                "type": "string"
              },
              "algorithm": {
                "const": "ed25519"
              },
              "publicKey": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "sigstore": {
          "type": "object",
          "required": ["certificateIdentities", "certificateOidcIssuers"],
          "properties": {
            "certificateIdentities": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "certificateOidcIssuers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "format": "uri"
              },
              "uniqueItems": true
            },
            "bundleVerification": {
              "enum": ["metadata", "cosign"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
