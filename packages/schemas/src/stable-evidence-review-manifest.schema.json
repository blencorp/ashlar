{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ashlar.dev/schemas/stable-evidence-review-manifest.schema.json",
  "title": "Ashlar Stable Evidence Review Manifest",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "artifactType",
    "component",
    "version",
    "automatedStatus",
    "stableClaim",
    "requiresManualReview",
    "generatedBy",
    "files"
  ],
  "properties": {
    "$schema": {
      "const": "https://ashlar.dev/schemas/stable-evidence-review-manifest.schema.json"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "artifactType": {
      "const": "stable-evidence-review-bundle"
    },
    "component": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "automatedStatus": {
      "enum": ["pass", "fail"]
    },
    "stableClaim": {
      "const": false
    },
    "requiresManualReview": {
      "const": true
    },
    "generatedBy": {
      "type": "object",
      "required": ["command", "registry", "fixture"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "registry": {
          "type": "string",
          "minLength": 1
        },
        "fixture": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "files": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": ["role", "path", "bytes", "mutableByReviewer", "sha256"],
        "properties": {
          "role": {
            "enum": [
              "automated-evidence",
              "proposed-evidence",
              "manual-evidence-worksheet",
              "keyboard-transcript-worksheet",
              "screen-reader-transcript-worksheet",
              "reviewer-harness",
              "github-issue-body",
              "reviewer-checklist",
              "reviewer-readme"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "mutableByReviewer": {
            "type": "boolean"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
