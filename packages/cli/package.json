{
  "name": "@blen/ashlar-cli",
  "version": "0.3.23",
  "description": "Command-line implementation for Ashlar source capsules, audits, themes, and provenance checks.",
  "keywords": [
    "accessibility",
    "ai",
    "cli",
    "design-system",
    "government",
    "public-services",
    "registry",
    "ui"
  ],
  "homepage": "https://github.com/blencorp/ashlar#readme",
  "bugs": {
    "url": "https://github.com/blencorp/ashlar/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/blencorp/ashlar.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "ashlar": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/registry/**",
    "!dist/**/*.test.*",
    "!dist/**/*.tsbuildinfo",
    "themes"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/copy-cli-registry.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile dist/tsconfig.typecheck.tsbuildinfo",
    "test": "pnpm build && vitest run --exclude \"dist/**\"",
    "lint": "biome lint src"
  },
  "dependencies": {
    "@blen/ashlar-schemas": "workspace:*",
    "@ast-grep/napi": "catalog:",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "commander": "catalog:",
    "fast-glob": "catalog:",
    "parse5": "catalog:",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
